# Environment
ENVIRONMENT=development

# CORS — comma-separated origins. Override via ENV var as JSON list if deploying:
#   CORS_ORIGINS=["https://app.klypup.com"]
# Default used by pydantic-settings is localhost dev origins.

# Firebase Admin
FIREBASE_PROJECT_ID=
# Provide EITHER a path to the service account JSON file on disk:
FIREBASE_CREDENTIALS_PATH=
# OR inline JSON string (useful for Cloud Run / Secret Manager):
FIREBASE_CREDENTIALS_JSON=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
