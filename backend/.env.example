# Copy to backend/.env and fill with real values. Never commit the filled file.

ENVIRONMENT=development

# Firebase Admin
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=./firebase-admin.json
# Optional — paste the full admin JSON as one line if running where a file isn't practical (Render, Cloud Run).
FIREBASE_CREDENTIALS_JSON=

# Gemini (AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Supabase (service-role key — backend only, NEVER expose to browser)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=

# News
NEWS_API_KEY=
GNEWS_API_KEY=

# Market data
FMP_API_KEY=
ALPHA_VANTAGE_KEY=

# Reddit (optional — disables /api/social reddit data if blank)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=klypup-research/1.0 (by /u/your-handle)

# SEC EDGAR requires a real contact email
SEC_USER_AGENT=Your Name your-email@example.com

# CORS (production only; default covers localhost dev)
# CORS_ORIGINS=["https://your-hosting-domain.web.app"]
