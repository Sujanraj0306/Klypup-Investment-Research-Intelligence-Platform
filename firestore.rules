rules_version = '2';

// Klypup Firestore security rules — single-user-per-org model.
// Every user owns exactly one org with id "org_<uid>". The backend uses the
// Admin SDK which bypasses these rules; browser clients are constrained here.

service cloud.firestore {
  match /databases/{database}/documents {

    // The user's own profile document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Org-scoped data: watchlist, reports, metadata, etc.
    // The org id must equal "org_<caller-uid>".
    match /orgs/{orgId}/{document=**} {
      allow read, write:
        if request.auth != null && orgId == 'org_' + request.auth.uid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
