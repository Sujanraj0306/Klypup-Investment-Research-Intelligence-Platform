# Copy to frontend/.env.production and fill in BEFORE running `npm run build`.
# All values here ship to the browser; Firebase web-app config and the
# Supabase anon key are safe to expose (RLS enforces org isolation).

# Render / Cloud Run backend URL after deploy
VITE_API_BASE_URL=https://your-api.onrender.com

# Firebase web-app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Supabase (anon / publishable key)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=
