# Copy to frontend/.env.local and fill with real values. Never commit the filled file.

# Firebase web-app config (safe to expose — these are public by design)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Supabase (anon / publishable key — safe to expose, RLS enforces isolation)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Backend API base URL
VITE_API_BASE_URL=http://localhost:8000
